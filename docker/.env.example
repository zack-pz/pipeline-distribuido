# Copiá este archivo a `.env` dentro de la carpeta `docker/` si querés
# personalizar cómo se levantan los contenedores con Docker Compose.

# ===== Coordinator =====
COORDINATOR_BIND_ADDR=0.0.0.0:9001
COORDINATOR_PORT=9001

# ===== Edge =====
EDGE_ID=edge-1
EDGE_BIND_ADDR=0.0.0.0:8001
EDGE_PORT=8001
COORDINATOR_ADDR=coordinator:9001

# ===== Sensor =====
SENSOR_ID=sensor-1
EDGE_ADDR=edge:8001
INTERVAL_MS=1000

# ===== Logging =====
RUST_LOG=info
